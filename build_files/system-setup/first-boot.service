[Unit]
Description=System-wide first boot setup
After=network-online.target
Wants=network-online.target
# This marker ensures it only runs once
ConditionPathExists=!/var/lib/system-first-boot-done

[Service]
Type=oneshot
ExecStart=/usr/libexec/system-setup/system-first-boot.sh
# Create the marker file after successful execution
ExecStartPost=/usr/bin/touch /var/lib/system-first-boot-done
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
